@using EntityLayer.Concrete
@model List<Description>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/UserLayout.cshtml";
}


<div class="container bg-dark">
    <div class="row">
        <!-- Blog entries-->
        <div class="col-lg-8">
            <!-- Featured blog post-->

            <!-- Nested row for non-featured blog posts-->
            <div class="row">
                
                @foreach (var item in Model)
                {

                 <div class="col-lg-6">
                    <!-- Blog post-->
                    <div class="card mb-4">
                        <a href="/Description/BlogDetails/@item.DescriptionID"><img class="card-img-top" src="@item.DescriptionThumbnailImage" alt="..." /></a>
                        <span class="badge bg-success position-absolute top-0 end-0 m-2">@item.Category.CategoryName</span>
                        <div class="card-body">
                            <div class="small text-muted">@(((DateTime)item.DescriptionCreateDate).ToString("dd-MM-yyyy"))</div>
                            <h2 class="card-title h4">@item.DescriptionTitle</h2>
                            <p class="card-text">@item.DescriptionContent.Substring(0,(item.DescriptionContent.Substring(0,135)).LastIndexOf(" ")) ...</p>
                            <a class="btn btn-primary" href="/Description/BlogDetails/@item.DescriptionID">Devamını gör →</a>
                        </div>
                    </div>
                 </div>
                }
            </div>
            <!-- Pagination-->
            <nav aria-label="Pagination">
                <hr class="my-0" />
                <ul class="pagination justify-content-center my-4">
                    <li class="page-item disabled"><a class="page-link" href="#" tabindex="-1" aria-disabled="true">En Yeni</a></li>
                    <li class="page-item active" aria-current="page"><a class="page-link" href="#!">1</a></li>
                    <li class="page-item"><a class="page-link" href="#!">2</a></li>
                    <li class="page-item"><a class="page-link" href="#!">3</a></li>
                    <li class="page-item disabled"><a class="page-link" href="#!">...</a></li>
                    <li class="page-item"><a class="page-link" href="#!">15</a></li>
                    <li class="page-item"><a class="page-link" href="#!">En Eski</a></li>
                </ul>
            </nav>
        </div>
        <!-- Side widgets-->
        <div class="col-lg-4">
            <!-- Search widget-->
            <div class="card mb-4 bg-black text-light">
                <div class="card-header text-warning">Bul</div>
                <div class="card-body">
                    <div class="input-group">
                        <input class="form-control" type="text" placeholder="Aranacak kelimeyi girin..." aria-label="Enter search term..." aria-describedby="button-search" />
                        <button class="btn btn-warning" id="button-search" type="button">Git!</button>
                    </div>
                </div>
            </div>
            <!-- Categories widget-->
           @await Component.InvokeAsync("CategoryList")
            
            <!-- Side widget-->
           @await Component.InvokeAsync("Last3Post") 
        </div>
    </div>
</div>
