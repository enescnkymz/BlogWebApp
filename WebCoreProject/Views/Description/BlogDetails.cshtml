@using EntityLayer.Concrete
@model Description

@{
    ViewData["Title"] = "BlogDetails";
    Layout = "~/Views/Shared/UserLayout.cshtml";
}

<div class="container mt-5 bg-dark text-light">
    <div class="row">
        <div class="col-lg-8">
            <!-- Post content-->
          
            
                <article>
                    <!-- Post header-->
                    <header class="mb-4">
                        <!-- Post title-->
                        <h1 class="fw-bolder mb-1">@Model.DescriptionTitle</h1>
                        <!-- Post meta content-->
                        <div class="text-muted fst-italic mb-2">@Model.DescriptionCreateDate.ToString("dd-MMMM-yyyy") tarihinde <a href="/Writer/WriterProfilePage/@Model.Writer.WriterID" >@Model.Writer.NameSurname</a> tarafından yazıldı. </div>
                        <!-- Post categories-->
                        <a class="badge bg-secondary text-decoration-none link-light" href="/Description/Index?categoryId=@Model.CategoryID">@Model.Category.CategoryName</a>
                    </header>
                    <!-- Preview image figure-->
                    <figure class="mb-4">
                        <img class="img-fluid rounded w-100"
                             src="@Model.DescriptionImage"
                             alt="..."
                             style="height:400px; object-fit:cover;" />
                    </figure>
                    <!-- Post content-->
                    <section class="mb-5">
                        <p class="fs-5 mb-4">@Model.DescriptionContent</p>
                    </section>
                </article>
            
            <!-- Comments section-->
            <section class="mb-5">
                <div class="card bg-black text-light">
                    <div class="card-body">
                        <!-- Comment form-->
                        @await Html.PartialAsync("~/Views/Comment/AddComment.cshtml", new Comment { DescriptionID = Model.DescriptionID })
                        <!-- Comment with nested comments-->
                        @await Component.InvokeAsync("CommentListByPost", new { id = Model.DescriptionID })

                    </div>
                </div>
            </section>
        </div>
                <!-- Side widgets-->
                <div class="col-lg-4">
                    <!-- Search widget-->
                    
                    <!-- Categories widget-->
                    @await Component.InvokeAsync("CategoryList") 
                    <!-- Side widget-->
                    @await Component.InvokeAsync("OtherPosts" , new { id = Model.WriterID})
                </div>
            </div>
</div>


