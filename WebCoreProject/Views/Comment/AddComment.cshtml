@model EntityLayer.Concrete.Comment

<form id="addComment">
    <div class="mb-3">
        <label for="Content" class="form-label">Yorum</label>
        <textarea class="form-control" id="Content" name="CommentContent" rows="3" placeholder="Yorumunuzu yazınız..." required></textarea>
    </div>

    <input type="hidden" name="DescriptionID" value="@Model.DescriptionID" />

    <button type="submit" class="btn btn-primary">Gönder</button>
    <div class="mb-5"></div>

</form>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $("#addComment").submit(function (e) {
        e.preventDefault();


        $.ajax({
            type: "POST",
            url: "/Comment/AddComment",
            data: $(this).serialize(),
            success: function () {
                $("#addComment")[0].reset();
            },

        });
    });
</script>
