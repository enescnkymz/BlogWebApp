@using EntityLayer.Concrete
@model Writer
@{
    ViewData["Title"] = "WriterProfilePage";
    Layout = "~/Views/Shared/WriterLayout.cshtml";
}

<link href="~/css/WriterProfilePage.css" rel="stylesheet" />



<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 rounded-4 bg-dark text-light">
                <div class="card-body p-0">
                    <div class="bg-primary bg-gradient text-white text-center p-4 rounded-top-4 shadow-sm" style="opacity: 0.9;">
                        <h2 class="mb-0 fw-bold">
                            <i class="bi bi-person-circle me-2"></i>
                            Yazar Profili
                        </h2>
                    </div>

                    <div class="p-4">
                        <div class="text-center mb-4">
                            <div class="position-relative d-inline-block">
                                <img src="@Model.WriterImage"
                                     alt="@Model.NameSurname"
                                     class="rounded-circle border border-4 border-primary shadow-lg"
                                     style="width: 180px; height: 180px; object-fit: cover; filter: brightness(0.9);">

                                @if (Model.WriterStatus == true)
                                {
                                    <span class="position-absolute bottom-0 end-0 badge bg-success rounded-pill px-3 py-2 shadow border border-2 border-dark">
                                        <i class="bi bi-check-circle-fill me-1"></i>
                                        Aktif
                                    </span>
                                }
                                else
                                {
                                    <span class="position-absolute bottom-0 end-0 badge bg-danger rounded-pill px-3 py-2 shadow border border-2 border-dark">
                                        <i class="bi bi-x-circle-fill me-1"></i>
                                        Pasif
                                    </span>
                                }
                            </div>

                            <h3 class="mt-4 mb-1 fw-bold text-white">@Model.NameSurname</h3>
                            <p class="text-info opacity-75">
                                <i class="bi bi-pen me-1"></i>
                                @Model.UserRole
                            </p>
                        </div>

                        <hr class="my-4 border-secondary opacity-25">

                        <div class="row g-3">
                            <div class="col-12">
                                <div class="card bg-secondary bg-opacity-10 border border-secondary border-opacity-25 h-100 shadow-sm">
                                    <div class="card-body">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-primary bg-opacity-25 rounded-3 p-3 me-3 text-primary">
                                                <i class="bi bi-envelope-fill fs-4"></i>
                                            </div>
                                            <div>
                                                <h6 class="text-info mb-1 small">E-posta Adresi</h6>
                                                <p class="mb-0 fw-semibold text-light">@Model.WriterMail</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="card bg-secondary bg-opacity-10 border border-secondary border-opacity-25 h-100 shadow-sm">
                                    <div class="card-body">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-body bg-opacity-25 rounded-3 p-3 me-3 text-light">
                                                <i class="bi bi-shield-check text-@(Model.WriterStatus==true ? "success" : "danger") fs-4"></i>
                                            </div>
                                            <div>
                                                <h6 class="text-info mb-1 small">Hesap Durumu</h6>
                                                <p class="mb-0 fw-semibold">
                                                    @if (Model.WriterStatus == true)
                                                    {
                                                        <span class="text-success">
                                                            <i class="bi bi-check-circle-fill me-1"></i>
                                                            Aktif Kullanıcı
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-danger">
                                                            <i class="bi bi-x-circle-fill me-1"></i>
                                                            Kısıtlı Hesap
                                                        </span>
                                                    }
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4">
                            <div class="card border border-secondary border-opacity-25 bg-secondary bg-opacity-10 shadow-sm">
                                <div class="card-body">
                                    <h5 class="card-title mb-3 text-info">
                                        <i class="bi bi-info-circle me-2"></i>
                                        Hakkımda
                                    </h5>
                                    <p class="card-text text-light opacity-75 mb-0" style="line-height: 1.8;">
                                        @Model.WriterAbout
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4 d-flex gap-2 justify-content-center">
                            <a href="/Description/Index?writerId=@Model.WriterID" class="btn btn-outline-info px-5 rounded-pill shadow-sm">
                                <i class="bi bi-file-text me-2"></i>
                                Tüm Yazıları Gör
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-3 mt-3">
                <div class="col-md-4">
                    <div class="card border-0 shadow-lg bg-dark text-light text-center border-top border-primary border-4">
                        <div class="card-body py-4">
                            <i class="bi bi-file-text text-primary fs-1 mb-2 opacity-75"></i>
                            <h4 class="mb-1 fw-bold text-white">@ViewBag.BlogCount</h4>
                            <p class="text-info small mb-0 text-uppercase ls-1">Yazı Sayısı</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-lg bg-dark text-light text-center border-top border-success border-4">
                        <div class="card-body py-4">
                            <i class="bi bi-eye text-success fs-1 mb-2 opacity-75"></i>
                            <h4 class="mb-1 fw-bold text-white">@ViewBag.ViewCount</h4>
                            <p class="text-success small mb-0 text-uppercase ls-1">Okunma</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-lg bg-dark text-light text-center border-top border-warning border-4">
                        <div class="card-body py-4">
                            <i class="bi bi-chat-dots text-warning fs-1 mb-2 opacity-75"></i>
                            <h4 class="mb-1 fw-bold text-white">@ViewBag.CommentCount</h4>
                            <p class="text-warning small mb-0 text-uppercase ls-1">Yorumlar</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


