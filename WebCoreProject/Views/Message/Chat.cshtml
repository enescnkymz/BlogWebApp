@using WebCoreProject.Models
@model SendMessageViewModel
@{
    ViewData["Title"] = "Chat";
    Layout = "~/Views/Shared/WriterLayout.cshtml";

    var activeTab = Context.Request.Query["activeTab"].ToString();
    if (string.IsNullOrEmpty(activeTab)) { activeTab = "Received"; };

}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mesajlar</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="~/css/Chat.css" rel="stylesheet" />
</head>

<body>

   <div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0 bg-dark text-light">
                <div class="card-header bg-primary bg-gradient text-white p-3 border-0">
                    <h5 class="mb-0 text-center">
                        <i class="fa fa-paper-plane me-2"></i>Yeni Mesaj Gönder
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form id="messageForm">
                        <div class="mb-3">
                            <label for="receiverMail" class="form-label fw-bold text-white-50">Alıcı E-posta</label>
                            <div class="input-group">
                                <span class="input-group-text bg-black border-secondary"><i class="fa fa-envelope text-primary"></i></span>
                                <input type="email" asp-for="ReceiverMail" class="form-control bg-dark text-white border-secondary shadow-none" placeholder="ornek@mail.com" required>
                            </div>
                            <span asp-validation-for="ReceiverMail" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label for="content" class="form-label fw-bold text-white-50">Mesajınız</label>
                            <textarea asp-for="MessageContent" class="form-control bg-dark text-white border-secondary shadow-none" rows="5" placeholder="Mesajınızı buraya yazın..." required style="resize: none;"></textarea>
                            <span asp-validation-for="MessageContent" class="text-danger small"></span>
                        </div>

                        <div class="d-grid">
                            <button id="sendButton" type="button" class="btn btn-primary btn-lg shadow-sm">
                                <i class="fa fa-paper-plane me-2"></i>Mesajı Gönder
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow-lg border-0 bg-dark overflow-hidden">
                <div class="card-body p-0">
                    <ul class="nav nav-tabs nav-fill bg-black border-0" id="messageTab" role="tablist" style="background-color: #0b0c0d;">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link text-primary bg-gradient-dark @(activeTab == "Received" ? "active ":"") py-3 fw-bold shadow-none" id="received-tab" data-bs-toggle="tab" data-bs-target="#received" type="button" role="tab">
                                <i class="fa fa-inbox me-2"></i>Gelen Mesajlar
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link text-success bg-gradient-dark @(activeTab == "Sent" ? "active ":"") py-3 fw-bold shadow-none" id="sent-tab" data-bs-toggle="tab" data-bs-target="#sent" type="button" role="tab">
                                <i class="fa fa-paper-plane me-2"></i>Giden Mesajlar
                            </button>
                        </li>
                    </ul>

                    <div class="tab-content p-4 text-light" id="messageTabContent">
                        <div class="tab-pane fade @(activeTab=="Received" ? "show active" : "" )" id="received" role="tabpanel">
                            <vc:received-message></vc:received-message>
                        </div>

                        <div class="tab-pane fade @(activeTab=="Sent" ? "show active" : "" )" id="sent" role="tabpanel">
                            <vc:sent-message></vc:sent-message>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>

        $("#sendButton").click(function (e) {
            e.preventDefault(); // Sayfa yenilenmesini engellemek için ŞART

            let messageData = {
                ReceiverMail: $("#ReceiverMail").val(),
                MessageContent: $("#MessageContent").val()
            };

            $.ajax({
                type: "post",
                url: "/Message/SendMessageAjax/",
                data: messageData,
                success: function (response) {
                    if (response.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Başarılı!',
                            text: response.message,
                            timer: 1000,
                            showConfirmButton: false
                        });
                        $("#content").val("");
                    }
                    else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Hata!',
                            text: response.message
                        });
                    }
                },
                error: function () {
                    console.log("Bağlantı hatası oluştu!");
                }
            });
        });

    </script>

</body>
</html>