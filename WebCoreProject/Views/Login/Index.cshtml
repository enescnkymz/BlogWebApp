@using WebCoreProject.Models

@model UserSignInViewModel

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/UserLayout.cshtml";
}


<link href="~/css/sign-in.css" rel="stylesheet" />
<script src="~/js/site.js"></script>


<main class="form-signin w-100 m-auto">
    <div style="height: 150px;"></div>

    <form method="post">

        <h1 class="h3 mb-3 fw-normal text-white">Lütfen giriş yapın</h1>

        <div class="text-danger mb-2" asp-validation-summary="ModelOnly"></div>

        <div class="form-floating mb-2">
            <input asp-for="Username" class="form-control" id="floatingInput" placeholder="Kullanıcı Adı" />
            <label for="floatingInput">Kullanıcı Adı</label>
            <span asp-validation-for="Username" class="text-danger"></span>
        </div>

        <div class="form-floating mb-2">
            <input asp-for="Password" type="password" class="form-control" id="floatingPassword" placeholder="Şifre" />
            <label for="floatingPassword">Şifre</label>
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <div class="form-check text-start my-3">
            <input class="form-check-input" type="checkbox" value="remember-me" id="checkDefault" />
            <label class="form-check-label text-light" for="checkDefault">
                Beni Hatırla
            </label>
        </div>

        <button class="btn btn-primary w-100 py-2" type="submit">
            Giriş Yap
        </button>

        <p class="mt-5 mb-3 text-body-secondary">&copy; @DateTime.Now.Year</p>
    </form>

    <div style="height: 300px;"></div>
</main>



