@using EntityLayer.Concrete
@model List<Category>




<div class="card mb-4 bg-black text-warning">
    <div class="card-header">Kategoriler</div>
    <div class="card-body">
        <div class="row">
            @foreach (var item in Model)
            {

                <div class="col-sm-6">
                    <ul class="list-unstyled mb-0">
                        <li><a href="#!" class="text-light">@item.CategoryName</a></li>
                    </ul>
                </div>
            
             }

        </div>
    </div>
</div>

