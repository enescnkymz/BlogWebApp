@using CoreLayer.Helpers
@using EntityLayer.Concrete
@model List<Notification>
@{
    Layout = null;
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

<li class="nav-item dropdown no-arrow mx-1">
    <a class="nav-link dropdown-toggle" href="#" id="alertsDropdown" role="button"
       data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
        <i class="fas fa-bell fa-fw "></i>
        @if (Model.Count() != 0)
        {
            <span class="badge badge-danger badge-counter">@(Model.Count() >= 4 ? "3+" : Model.Count().ToString())</span>
        }
    </a>

    <div class="dropdown-list dropdown-menu dropdown-menu-right shadow-lg animated--grow-in dropdown-menu-dark bg-dark border-secondary"
         aria-labelledby="alertsDropdown">

        <h6 class="dropdown-header bg-black text-white-50 border-0 py-3">Bildirimler</h6>

        @if (Model.Any())
        {
            foreach (var item in Model.Take(3))
            {
                string iconClass = "";
                string colorClass = "";

                switch (item.NotificationType)
                {
                    case NotificationTypeEnum.Message: iconClass = "bi-chat-dots-fill"; colorClass = "bg-primary"; break;
                    case NotificationTypeEnum.Task: iconClass = "bi-check-circle-fill"; colorClass = "bg-success"; break;
                    case NotificationTypeEnum.Warning: iconClass = "bi-exclamation-triangle-fill"; colorClass = "bg-warning"; break;
                    case NotificationTypeEnum.Offer: iconClass = "bi-gift-fill"; colorClass = "bg-info"; break;
                    case NotificationTypeEnum.Like: iconClass = "bi-heart-fill"; colorClass = "bg-danger"; break;
                    case NotificationTypeEnum.Upload: iconClass = "bi-cloud-upload-fill"; colorClass = "bg-secondary"; break;
                    default: iconClass = "bi-bell-fill"; colorClass = "bg-primary"; break;
                }

                <a class="dropdown-item d-flex align-items-center border-bottom border-secondary border-opacity-25 py-3 text-white" href="#">
                    <div class="mr-3">
                        <div class="icon-circle @colorClass text-white bg-opacity-75">
                            <i class="@iconClass"></i>
                        </div>
                    </div>
                    <div>
                        <div class="small text-info opacity-75">@DateHelpers.TimeAgo(item.NotificationDate)</div>
                        <span class="text-white">@item.NotificationDetails</span>
                    </div>
                </a>
            }
        }
        

        <a class="dropdown-item text-center small text-info bg-black border-0 py-2" href="/Notification/AllNotifications">
            Tüm Bildirimleri Gör
        </a>
    </div>
</li>