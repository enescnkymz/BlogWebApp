@using CoreLayer.Helpers
@using EntityLayer.Concrete
@model List<Message>

@{
    Layout = null;
}

<li class="nav-item dropdown no-arrow mx-1">
    <a class="nav-link dropdown-toggle" href="#" id="messagesDropdown" role="button"
       data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
        <i class="fas fa-envelope fa-fw "></i>

        @if (Model.Count() != 0)
        {
            <span class="badge badge-danger badge-counter">@(Model.Count() >= 4 ? "3+" : Model.Count().ToString())</span>
        }
    </a>

    <div class="dropdown-list dropdown-menu dropdown-menu-right shadow-lg animated--grow-in dropdown-menu-dark bg-dark border-secondary"
         aria-labelledby="messagesDropdown">

        <h6 class="dropdown-header bg-black border-0 text-white-50 py-3">
            Mesajlar
        </h6>

        @foreach (var item in Model.Take(3))
        {
            <a class="dropdown-item d-flex align-items-center border-bottom border-secondary border-opacity-25 py-3" href="#">
                <div class="dropdown-list-image mr-3">
                    <img class="rounded-circle border border-secondary" src="@item.Sender.WriterImage"
                         alt="..." style="width: 40px; height: 40px; object-fit: cover;">
                </div>
                <div class="w-100">
                    <div class="text-truncate text-white" style="max-width: 200px;">
                        @item.MessageDetails
                    </div>
                    <div class="small text-info opacity-75 mt-1">
                        @item.Sender.NameSurname · @DateHelpers.TimeAgo(item.MessageDate)
                    </div>
                </div>
            </a>
        }

        <a class="dropdown-item text-center small text-info bg-black border-0 py-2" href="/Message/Chat">
            Tüm Mesajları Gör
        </a>
    </div>
</li>



