@using EntityLayer.Concrete
@model List<Comment>
@using CoreLayer.Helpers



@if (Model.Count() != 0)
{

    @foreach (var item in Model)
    {

        <div class="d-flex mb-3">

            <a href="/Writer/WriterProfilePage/@item.CommentSender.WriterID">
                <div class="flex-shrink-0">
                    <img class="rounded-circle "
                         src="@item.CommentSender.WriterImage"
                         alt="@item.CommentSender.WriterName"
                         style="width: 50px; height: 50px; object-fit: cover;" />
                </div>
            </a>

            <div class="ms-3 w-100">
                <div class="d-flex justify-content-between align-items-center">
                    <a href="/Writer/WriterProfilePage/@item.CommentSender.WriterID" class="text-decoration-none text-white">
                        <div class="fw-bold">@item.CommentSender.NameSurname</div>
                    </a>
                    <small class="text-white-50">@DateHelpers.TimeAgo(item.CommentDate)</small>
                </div>

                <div class="text">
                    @item.CommentContent
                </div>
            </div>

        </div>

    }

}

else
{
<div class="text-center py-5 px-3 bg-dark bg-opacity-50 rounded-4 border border-secondary border-opacity-25 my-4">
    <i class="bi bi-chat-square-quote text-white-50 mb-3 d-block" style="font-size: 3rem;"></i>

    <h5 class="text-light fw-bold mb-2">Henüz yorum yapılmamış</h5>

    
</div>
}
