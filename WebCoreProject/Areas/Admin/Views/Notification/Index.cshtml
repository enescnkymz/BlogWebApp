@using EntityLayer.Concrete
@model List<Notification>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="wrapper wrapper-content">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox">
                <div class="ibox-title">
                    <h5>Yeni Bildirim Oluştur</h5>
                </div>
                <div class="ibox-content">
                    <form method="post" action="/Admin/Notification/AddNotification">
                        <div class="row">
                            <div class="col-sm-3">
                                <div class="form-group">
                                    <label class="col-form-label">Alıcı ID</label>
                                    <input type="number" name="WriterID" class="form-control" placeholder="Herkes için boş bırakın" >
                                </div>
                            </div>
                            <div class="col-sm-3">
                                <div class="form-group">
                                    <label class="col-form-label">Bildirim Türü</label>
                                    <select class="form-control" name="NotificationType">
                                        @foreach (var type in Enum.GetValues(typeof(NotificationTypeEnum)))
                                        {
                                            <option value="@((int)type)">@type.ToString()</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="form-group">
                                    <label class="col-form-label">Bildirim İçeriği</label>
                                    <input type="text" name="NotificationDetails" class="form-control" placeholder="Mesajınızı buraya yazın..." required>
                                </div>
                            </div>
                        </div>
                        <div class="hr-line-dashed"></div>
                        <div class="form-group">
                            <button class="btn btn-primary btn-sm" type="submit">Bildirimi Gönder</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-12">
            <div class="ibox">
                <div class="ibox-title">
                    <h5>Geçmiş Bildirimler</h5>
                </div>
                <div class="ibox-content">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Tür</th>
                                    <th>Alıcı</th>
                                    <th>İçerik</th>
                                    <th>Tarih</th>
                                    <th>İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.NotificationID</td>
                                        <td>                                          
                                            <span class="badge">
                                                @item.NotificationType
                                            </span>
                                        </td>
                                        <td>@(item.WriterID== null ? "Herkes" : item.WriterID )</td>
                                        <td>@item.NotificationDetails</td>
                                        <td>@(((DateTime)item.NotificationDate).ToString("dd-MMM-yyyy"))</td>
                                        <td>
                                            <a href="/Admin/Notification/DeleteNotification/@item.NotificationID"
                                               class="btn btn-danger btn-xs">
                                                <i class="fa fa-trash"></i> Sil
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>