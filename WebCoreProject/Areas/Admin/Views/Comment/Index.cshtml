@using BusinessLayer.DTOs
@model X.PagedList.IPagedList<CommentAdminDto>
@using X.PagedList.Mvc.Core


@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<!DOCTYPE html>
<html>



<body>
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox">
                <div class="ibox-content">

                    <table class="footable table table-stripped toggle-arrow-tiny" data-page-size="15">
                        <thead>
                            <tr>

                                <th>Yorum Sahibi</th>
                                <th data-hide="phone">Yorum</th>
                                <th data-hide="phone">Yazı</th>
                                <th data-hide="phone">Yazılma Tarihi</th>
                                <th data-hide="phone,tablet">Yorum ID</th>
                                <th data-hide="phone">Durum</th>
                                <th class="text-right"></th>

                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {

                                <tr>
                                    <td>
                                        @item.CommentSenderName
                                    </td>
                                    <td>
                                        @item.CommentContent
                                    </td>
                                    <td>
                                        @item.CommentPost
                                    </td>
                                    <td>
                                        @item.CommentCreateDate
                                    </td>
                                    <td>
                                        @item.CommentId
                                    </td>
                                    <td>
                                        @if (item.CommentStatus)
                                        {
                                            <span class="label label-primary">Aktif</span>
                                        }

                                    </td>
                                    <td class="text-right">
                                        <div class="btn-group">
                                            <a asp-area="" asp-action="BlogDetails" asp-controller="Description" asp-route-id="@item.CommentPostId" class="btn-white btn btn-xs">Yazı</a>
                                            <a asp-area="" asp-action="WriterProfilePage" asp-controller="Writer" asp-route-id="@item.CommentSenderId" class="btn-white btn btn-xs">Yazar</a>
                                            <a asp-action="DeleteComment" asp-controller="Comment" asp-route-id="@item.CommentId" class="btn-white btn btn-xs">Sil</a>
                                        </div>
                                    </td>
                                </tr>
                            }

                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="7">
                                    <ul class="pagination float-right">
                                        @Html.PagedListPager(Model, page => Url.Action("Index", new { page }),
                                        new PagedListRenderOptions
                                        {
                                        LiElementClasses = new string[] { "page-item" },
                                        PageClasses = new string[] { "page-link" }
                                        })
                                    </ul>
                                </td>
                            </tr>
                        </tfoot>
                    </table>

                </div>
            </div>
        </div>
    </div>
</body>

</html>



