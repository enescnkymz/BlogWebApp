@using EntityLayer.Concrete
@model List<Message>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}



<div class="wrapper wrapper-content">
    <div class="ibox">
        <div class="ibox-title">
            <h5>Tüm Mesaj Trafiği</h5>
        </div>
        <div class="ibox-content">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Gönderen</th>
                        <th class="text-center"></th>
                        <th>Alıcı</th>
                        <th>Mesaj Detayı</th>
                        <th>Tarih</th>
                        <th>İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <img src="@item.Sender.WriterImage" class="img-circle" width="30" height="30" style="object-fit:cover">
                                <small class="m-l-sm">@item.Sender.WriterName</small>
                            </td>

                            <td class="text-center">
                                <i class="fa fa-arrow-right text-info"></i>
                            </td>

                            <td>
                                <img src="@item.Receiver.WriterImage" class="img-circle" width="30" height="30" style="object-fit:cover">
                                <small class="m-l-sm">@item.Receiver.WriterName</small>
                            </td>

                            <td>
                                <strong>@item.MessageDetails</strong>
                               
                            </td>

                            <td>
                                <span class="small">@(((DateTime)item.MessageDate).ToString("dd.MM.yyyy HH:mm"))</span>
                            </td>

                            <td>
                                <a asp-area="Admin" asp-controller="Message" asp-action="DeleteMessage" asp-route-id="@item.MessageID"
                                   class="btn btn-danger btn-xs">
                                    <i class="fa fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

